#include <iostream>
#include <vector>
#include <cmath>
#include <algorithm>
#include <ctime>

using namespace std;

void merge(int arr[], int l, int m, int r) {
    int n1 = m - l + 1, n2 = r - m;
    int L[n1], R[n2];
    for (int i = 0; i < n1; i++) L[i] = arr[l + i];
    for (int j = 0; j < n2; j++) R[j] = arr[m + 1 + j];
    int i = 0, j = 0, k = l;
    while (i < n1 && j < n2) arr[k++] = (L[i] <= R[j]) ? L[i++] : R[j++];
    while (i < n1) arr[k++] = L[i++];
    while (j < n2) arr[k++] = R[j++];
}

void mergeSort(int arr[], int l, int r) {
    if (l < r) {
        int m = l + (r - l) / 2;
        mergeSort(arr, l, m);
        mergeSort(arr, m + 1, r);
        merge(arr, l, m, r);
    }
}

int jumpSearch(int arr[], int x, int n) {
    int step = sqrt(n);
    int prev = 0;
    while (arr[min(step, n) - 1] < x) {
        prev = step;
        step += sqrt(n);
        if (prev >= n) return -1;
    }
    while (arr[prev] < x) {
        prev++;
        if (prev == min(step, n)) return -1;
    }
    return (arr[prev] == x) ? prev : -1;
}

int main() {
    const int n = 100;
    int data[n];
    srand(time(0));

    for (int i = 0; i < n; i++) data[i] = i + 1;
    random_shuffle(data, data + n);

    cout << "DATA AWAL (ACAK):" << endl;
    for (int i = 0; i < n; i++) cout << data[i] << " ";
    
    mergeSort(data, 0, n - 1);
    
    int target = data[rand() % n];
    
    cout << "\n\nDATA SETELAH SORTING (Target: " << target << "):" << endl;
    for (int i = 0; i < n; i++) {
        if (data[i] == target) cout << "[" << data[i] << "] ";
        else cout << data[i] << " ";
    }

    cout << "\n\n--- PROSES PENCARIAN JUMP SEARCH ---" << endl;
    int hasil = jumpSearch(data, target, n);

    if (hasil != -1) {
        cout << "SUKSES: Angka " << target << " ditemukan pada indeks ke-" << hasil << endl;
    } else {
        cout << "Gagal menemukan angka." << endl;
    }

    return 0;
}
